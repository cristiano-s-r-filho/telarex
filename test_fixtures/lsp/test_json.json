{
  "project": {
    "name": "geometry-engine",
    "version": "2.1.0",
    "description": "2D geometry computation library",
    "license": "MIT"
  },
  "dependencies": [
    { "name": "lodash", "version": "^4.17.21", "optional": false },
    { "name": "jest", "version": "^29.0.0", "optional": true }
  ],
  "shapes": {
    "triangle": {
      "vertices": 3,
      "area_formula": "0.5 * |cross(p2-p1, p3-p1)|",
      "properties": ["perimeter", "centroid", "incenter"]
    },
    "circle": {
      "vertices": 1,
      "area_formula": "PI * r^2",
      "properties": ["circumference", "diameter", "sector"]
    }
  },
  "test_cases": [
    {
      "name": "right_triangle",
      "points": [
        { "x": 0, "y": 0 },
        { "x": 3, "y": 0 },
        { "x": 0, "y": 4 }
      ],
      "expected_area": 6.0
    }
  ]
}
